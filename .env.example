# ─── Required ────────────────────────────────────────────────
ANTHROPIC_API_KEY=        # Your Anthropic API key
GH_TOKEN=                 # GitHub personal access token (repo scope)
GH_REPO=                  # Your repo in the format username/jobbud
DASHBOARD_PASSWORD=       # Password gate for the dashboard. Required: the
                          # dashboard fails closed and serves no job data
                          # (401) unless this is set, so use a strong value.
                          # (The GitHub Actions scanner pipeline runs without
                          # it; only the Vercel dashboard needs it.)

# ─── Optional: Dashboard ─────────────────────────────────────
ACTION_TOKEN_SECRET=      # Signs the action links in digest/reminder emails.
                          # Optional: falls back to DASHBOARD_PASSWORD when unset.
                          # Set a dedicated random value so links don't reuse the
                          # dashboard password. Must match between GitHub Actions
                          # (which mints links) and Vercel (which verifies them).

# ─── Optional: Google Drive (auto-save prep docs) ────────────
# Full step-by-step setup — including how to mint GOOGLE_REFRESH_TOKEN
# with get-google-token.mjs — is in SETUP.md. Leave all four blank to
# skip the feature; prep docs then generate in a copy/download popup.
GOOGLE_CLIENT_ID=         # OAuth 2.0 client ID
GOOGLE_CLIENT_SECRET=     # OAuth 2.0 client secret
GOOGLE_REFRESH_TOKEN=     # OAuth 2.0 refresh token (mint via `node get-google-token.mjs`)
                          # Note: keep your OAuth app in Production
                          # mode or tokens expire after 7 days
GOOGLE_DRIVE_FOLDER_ID=   # Optional. Drive folder ID to save prep docs into.
                          # Leave blank to save to your Drive root.

# ─── Optional: SendGrid (email digests) ──────────────────────
SENDGRID_API_KEY=
SENDGRID_FROM_EMAIL=      # Verified sender address
NOTIFICATION_EMAIL=       # Where digests are delivered

# ─── Optional: Telegram (push notifications) ─────────────────
TELEGRAM_BOT_TOKEN=
TELEGRAM_CHAT_ID=

# ─── Optional: Firecrawl (JS-rendered career pages) ──────────
FIRECRAWL_API_KEY=

# ─── Optional: API job sources (weekly API scan) ─────────────
# Extra job feeds beyond the portal/ATS scan. Each is independent —
# set only the ones you have. Without any, JobBud still scans the
# portals and company career pages configured in scanner/portals.yml.
JSEARCH_API_KEY=          # RapidAPI JSearch
ADZUNA_APP_ID=            # Adzuna app ID
ADZUNA_API_KEY=           # Adzuna app key
SERP_API_KEY=             # SerpApi (Google Jobs results)

# ─── Optional: Vercel (for tappable Telegram links) ──────────
VERCEL_URL=               # e.g. your-app.vercel.app (no https://)

# ─── Optional: Scanner scoring mode ──────────────────────────
USE_BATCH_API=            # Opt-in, off by default. Routes both scoring stages
                          # through Anthropic's Message Batches API, which bills
                          # every token at 50% of standard price — halving the
                          # Anthropic scoring cost of scheduled scans. TRADEOFF:
                          # batches run asynchronously and the workflow idle-polls
                          # for the result, keeping a GitHub Actions runner busy
                          # ~20–40 min per scan (~600–1,200 free-tier minutes a
                          # month) instead of the ~6 min a synchronous scan takes.
                          # Only worth it if JobBud is the main thing using your
                          # private-repo Actions minutes. To enable, add
                          # `USE_BATCH_API: 'true'` back to the scanner step env in
                          # .github/workflows/scan.yml and .github/workflows/
                          # weekly-api-scan.yml. Leave unset for the interactive
                          # Vercel path, which needs synchronous responses.
MAX_JOBS_TO_EVALUATE=     # Optional (default 50). Ceiling on jobs sent to the
                          # Stage-2 scorer per run. Stage 1 runs on all candidates;
                          # if more than this pass Stage 1, the lowest-confidence
                          # passers defer to the next run. The weekly API workflow
                          # raises this to 250.
