{
  "github": { "silent": true },
  "ignoreCommand": "git diff --quiet HEAD^ HEAD -- ':!data' ':!*.md'",
  "cleanUrls": true,
  "rewrites": [
    { "source": "/dashboard",  "destination": "/dashboard/index.html" },
    { "source": "/dashboard/", "destination": "/dashboard/index.html" }
  ],
  "functions": {
    "api/action.js": {
      "maxDuration": 120
    },
    "api/add-job.js": {
      "maxDuration": 60
    },
    "api/jobs.js": {
      "maxDuration": 10
    },
    "api/coach.js": {
      "maxDuration": 120
    }
  }
}
