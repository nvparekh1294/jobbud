{
  "github": { "silent": true },
  "ignoreCommand": "if git rev-parse -q --verify HEAD^ >/dev/null 2>&1; then git diff --quiet HEAD^ HEAD -- ':!data' ':!*.md'; else exit 1; fi",
  "cleanUrls": true,
  "rewrites": [
    { "source": "/",          "destination": "/dashboard/index.html" },
    { "source": "/dashboard",  "destination": "/dashboard/index.html" },
    { "source": "/dashboard/", "destination": "/dashboard/index.html" }
  ],
  "functions": {
    "api/action.js": {
      "maxDuration": 120
    },
    "api/add-job.js": {
      "maxDuration": 60
    },
    "api/jobs.js": {
      "maxDuration": 10
    },
    "api/coach.js": {
      "maxDuration": 120
    },
    "api/memory.js": {
      "maxDuration": 60
    }
  }
}
